# .env.example -- production configuration template for a markgo deployment.
#
# Copy to .env on the deploy target, fill in real values, then secure it:
#   chmod 600 /opt/log.1mb.dev/.env
#
# Every knob below is documented in detail in markgo's own .env.example:
#   https://github.com/1mb-dev/markgo/blob/main/.env.example
#
# Conventions in this file:
# - `your...` strings are placeholders -- replace them.
# - Notes call out values matched to the reference deployment (log.1mb.dev).
# - Empty values are intentionally optional or disabled by default.

# ============================================================================
# CORE
# ============================================================================

# production | development | test
ENVIRONMENT=production

# Bind port. Reference deployment uses 3001 to coexist with other services on
# the same host. Caddy upstream targets this port (see deploy/Caddyfile.example).
PORT=3001

# Public URL of your blog. Drives canonical links, RSS feeds, OG cards, sitemap.
BASE_URL=https://yourdomain.com

# ============================================================================
# PATHS
# Relative to the systemd WorkingDirectory in deploy/log.service.example.
# ============================================================================

ARTICLES_PATH=./articles
# Markgo's static handler is overlay mode (filesystem-first, embedded fallback)
# since v3.10.2. Setting STATIC_PATH=./static serves your overrides where
# present and falls back to markgo's embedded defaults for everything else. No
# need to mirror markgo's full web/static/ tree. Leave empty to serve only
# embedded defaults.
STATIC_PATH=
UPLOAD_PATH=./uploads

# Templates: markgo ships embedded defaults. Uncomment only if you fork them.
# TEMPLATES_PATH=./web/templates

# ============================================================================
# BLOG IDENTITY
# ============================================================================

BLOG_TITLE=Your Blog Title
BLOG_TAGLINE=Your tagline
BLOG_DESCRIPTION=Your blog description.
BLOG_AUTHOR=Your Name
# markgo v3.15.1+ : empty value hides the email card on /about and omits the
# email field in JSON-LD. Set a real address to show the card.
BLOG_AUTHOR_EMAIL=
BLOG_LANGUAGE=en
BLOG_THEME=default
# Picks the theme CSS file at /static/css/themes/<BLOG_STYLE>.css. Ships with
# "minimal"; markgo v3.10.3+ accepts any non-empty value, so drop a custom
# theme into your STATIC_PATH overlay and set BLOG_STYLE=<yourname>.
BLOG_STYLE=minimal
BLOG_POSTS_PER_PAGE=10

# ============================================================================
# ABOUT PAGE
# All optional. If you'd rather use articles/about.md, leave these empty.
# ============================================================================

ABOUT_AVATAR=
ABOUT_TAGLINE=
ABOUT_BIO=
ABOUT_LOCATION=
ABOUT_GITHUB=
ABOUT_TWITTER=
ABOUT_LINKEDIN=
ABOUT_MASTODON=
ABOUT_WEBSITE=

# /about reach section copy. markgo v3.15.0+ exposes the section heading and
# email card via these vars; defaults match the pre-v3.15.0 hardcoded literals.
# AMA card copy is driven by the AMA_PAGE_* vars (also configurable; see markgo
# .env.example for the full set).
# ABOUT_REACH_HEADING=Reach out
# ABOUT_EMAIL_HEADING=Email
# ABOUT_EMAIL_INTRO=Or drop a line directly.

# ============================================================================
# ADMIN + AMA
# Admin credentials gate /compose (publishing) and /admin/ama (moderation).
# AMA submissions are only accepted when ADMIN_USERNAME and ADMIN_PASSWORD are set.
# Use strong values -- sessions are 7-day cookies, cleared on restart.
# ============================================================================

ADMIN_USERNAME=
ADMIN_PASSWORD=

# ============================================================================
# RATE LIMITS
# ============================================================================

# General routes (article reads, feeds).
RATE_LIMIT_GENERAL_REQUESTS=100
RATE_LIMIT_GENERAL_WINDOW=900s

# Contact form AND public AMA submissions (POST /ama/submit) share this stricter limit.
# Spam protection on AMA also relies on markgo's built-in math captcha and honeypot.
RATE_LIMIT_CONTACT_REQUESTS=5
RATE_LIMIT_CONTACT_WINDOW=3600s

# ============================================================================
# CORS
# Production: list your domain(s) only. Wildcards are a footgun.
# ============================================================================

CORS_ALLOWED_ORIGINS=https://yourdomain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Origin,Content-Type,Accept,Authorization

# ============================================================================
# EMAIL (CONTACT FORM)
# Leave EMAIL_HOST empty to disable the contact form entirely.
# AMA does not use SMTP -- submissions land in markgo's moderation queue on disk.
# ============================================================================

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
EMAIL_USE_SSL=true

# ============================================================================
# CACHE
# Production-tuned. Raise CACHE_TTL when content changes are infrequent.
# ============================================================================

CACHE_TTL=24h
CACHE_MAX_SIZE=1000
CACHE_CLEANUP_INTERVAL=10m

# ============================================================================
# SERVER TIMEOUTS
# Raise SERVER_WRITE_TIMEOUT if you allow large uploads via /compose.
# ============================================================================

SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_IDLE_TIMEOUT=60s

# ============================================================================
# LOGGING
# Production: warn (or info) + JSON + rotated file.
# ============================================================================

LOG_LEVEL=warn
LOG_FORMAT=json
LOG_OUTPUT=file
LOG_FILE=./logs/markgo.log
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=3
LOG_MAX_AGE=28
LOG_COMPRESS=true
LOG_ADD_SOURCE=false
# Go time format string for text-log timestamps. Default is RFC3339.
LOG_TIME_FORMAT=2006-01-02T15:04:05Z07:00

# ============================================================================
# SEO
# ============================================================================

SEO_ENABLED=true
SEO_SITEMAP_ENABLED=true
SEO_SCHEMA_ENABLED=true
SEO_OPEN_GRAPH_ENABLED=true
SEO_TWITTER_CARD_ENABLED=true

SEO_ROBOTS_ALLOWED=/
SEO_ROBOTS_DISALLOWED=/admin,/api,/compose,/login
SEO_ROBOTS_CRAWL_DELAY=1

# Drop a 1200x630 PNG at static/og-default.png for a default social card.
SEO_DEFAULT_IMAGE=/static/og-default.png

SEO_TWITTER_SITE=
SEO_TWITTER_CREATOR=
SEO_FACEBOOK_APP_ID=
SEO_GOOGLE_SITE_VERIFY=
SEO_BING_SITE_VERIFY=

# ============================================================================
# UPLOADS
# 10 MB default. Markgo writes uploads to UPLOAD_PATH/<slug>/.
# ============================================================================

UPLOAD_MAX_SIZE=10485760

# ============================================================================
# AMA COPY (markgo v3.11.0+)
# Plaintext only — HTML-escaped on render. Multi-line collapses; paragraph
# breaks require TEMPLATES_PATH override. Defaults shown below are markgo's;
# uncomment and override for your voice.
# ============================================================================

#AMA_PAGE_HEADING=Ask me anything
#AMA_PAGE_INTRO=Curious about something? Submit a question and I'll answer it publicly.
#AMA_FORM_PLACEHOLDER=What would you like to know?
#AMA_SUBMIT_LABEL=Submit Question
#AMA_THANKYOU_COPY=Question submitted! It will appear once answered.
