# deploy/log.service.example -- systemd unit for the markgo binary serving log.1mb.dev.
#
# Install:
#   sudo cp deploy/log.service.example /etc/systemd/system/log.service
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now log.service
#
# Modeled on markgo's own deployments/etc/systemd/system/markgo.service.
# When forking, edit User, paths, and EnvironmentFile to match your setup.

[Unit]
Description=markgo -- log.1mb.dev
Documentation=https://github.com/1mb-dev/log
After=network.target
Wants=network.target

[Service]
Type=simple
User=markgo
Group=markgo
WorkingDirectory=/opt/log.1mb.dev
ExecStart=/opt/log.1mb.dev/markgo
Restart=always
RestartSec=5
TimeoutStopSec=30

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/log.1mb.dev/logs /opt/log.1mb.dev/articles /opt/log.1mb.dev/uploads
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true

# Configuration: a dash prefix means "missing file is not fatal" while you bootstrap.
EnvironmentFile=-/opt/log.1mb.dev/.env

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=log

# Resource limits
LimitNOFILE=65536
LimitNPROC=4096

[Install]
WantedBy=multi-user.target
