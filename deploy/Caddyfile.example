# deploy/Caddyfile.example -- sample Caddy vhost block for a markgo deployment.
#
# Copy the block below into your existing Caddyfile, or use this file standalone:
#   sudo cp deploy/Caddyfile.example /etc/caddy/sites/log.1mb.dev.caddy
#   sudo systemctl reload caddy
#
# Caddy auto-provisions TLS via Let's Encrypt on first request -- no certbot needed.
# Replace `log.1mb.dev` with your domain before deploying.

log.1mb.dev {
	# Source-controlled banner images (per-article hero PNGs under static/img/banners/).
	# Markgo's STATIC_PATH is exclusive — setting it would replace embedded assets
	# wholesale and force forkers to mirror markgo's entire static surface. Instead,
	# Caddy overlays only the banners path from the deploy tree; markgo continues to
	# serve everything else from its embedded /static. Remove this block once markgo
	# supports STATIC_PATH overlay mode (tracked upstream:
	# https://github.com/1mb-dev/markgo/issues/59).
	handle /static/img/banners/* {
		root * /opt/log.1mb.dev
		file_server
	}

	# Markgo binds to localhost. Caddy fronts it for TLS, compression, and access logging.
	# The port must match PORT in .env. This reference deployment uses 3001 to coexist
	# with other services on the same host.
	reverse_proxy 127.0.0.1:3001

	# Security headers. CSP is authoritative; `frame-ancestors 'none'` supersedes
	# X-Frame-Options on modern browsers. Markgo emits X-Content-Type-Options,
	# Referrer-Policy, X-Frame-Options, and X-XSS-Protection — do not duplicate here.
	# `'unsafe-inline'` for script/style is required by markgo's inline scripts
	# (service worker registration, AMA math captcha). Tighten upstream when those
	# move to external files.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		Permissions-Policy "interest-cohort=(), browsing-topics=()"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		# Markgo controls Cache-Control for /static/* and /sw.js; do not override here.
	}

	encode gzip zstd

	# Access logs go to systemd journal via stderr. Query with:
	#   journalctl -u caddy --grep 'log.1mb.dev' -f
	# Swap to `output file /var/log/caddy/<domain>.access.log { roll_size 10mb }`
	# if you need rotated files (precondition: /var/log/caddy/ exists and
	# is writable by the caddy user).
	log {
		output stderr
		level INFO
	}
}
