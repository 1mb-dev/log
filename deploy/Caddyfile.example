# deploy/Caddyfile.example -- sample Caddy vhost block for a markgo deployment.
#
# Copy the block below into your existing Caddyfile, or use this file standalone:
#   sudo cp deploy/Caddyfile.example /etc/caddy/sites/log.1mb.dev.caddy
#   sudo systemctl reload caddy
#
# Caddy auto-provisions TLS via Let's Encrypt on first request -- no certbot needed.
# Replace `log.1mb.dev` with your domain before deploying.

log.1mb.dev {
	# Markgo binds to localhost. Caddy fronts it for TLS, compression, and access
	# logging. The port must match PORT in .env. This reference deployment uses 3001
	# to coexist with other services on the same host. Source-controlled static
	# assets (banners, favicons, og-default, theme CSS, fonts) ship from
	# /opt/log.1mb.dev/static and overlay markgo's embedded defaults via
	# STATIC_PATH=./static (markgo v3.10.2+).
	reverse_proxy 127.0.0.1:3001

	# Security headers are markgo-authoritative (v3.16.0+). Markgo emits CSP
	# (with SHA-256 hash for its single inline FOUC script), HSTS, Permissions-
	# Policy, X-Content-Type-Options, Referrer-Policy, and X-Frame-Options — do
	# not duplicate here. If you front markgo with an edge proxy that emits its
	# own CSP, set CSP_DISABLE=true in .env to suppress markgo's. Cache-Control
	# for /static/* and /sw.js is also markgo-controlled.

	encode gzip zstd

	# Access logs go to systemd journal via stderr. Query with:
	#   journalctl -u caddy --grep 'log.1mb.dev' -f
	# Swap to `output file /var/log/caddy/<domain>.access.log { roll_size 10mb }`
	# if you need rotated files (precondition: /var/log/caddy/ exists and
	# is writable by the caddy user).
	log {
		output stderr
		level INFO
	}
}
